{
  "expo": {
    "name": "bolt-expo-nativewind",
    "slug": "bolt-expo-nativewind",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
  "expo-router", 
  "expo-font", 
  "expo-web-browser",
  [
    "react-native-purchases",
    {
      "apiKey": "YOUR_REVENUECAT_IOS_API_KEY"
    }
  ]
],
    "experiments": {
      "typedRoutes": true
    }
  }
}
