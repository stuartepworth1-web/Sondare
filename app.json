{
  "expo": {
    "name": "sondare",
    "slug": "sondare",
    "version": "1.0.0",
    "owner": "stuartepworth",
    "extra": {
      "eas": {
        "projectId": "b4618b87-bdcf-49db-ac8a-d36d03bd8aca"
      }
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": ["expo-router", "expo-font", "expo-web-browser"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
